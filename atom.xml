    <title>操作系统上机实验（三）存储管理——动态不等长存储资源分配算法</title>
    <link href="https://txaxsimer.github.io/2022/06/16/%E6%93%8D%E4%BD%9C%E7%B3%BB%E7%BB%9F%E4%B8%8A%E6%9C%BA%E5%AE%9E%E9%AA%8C%EF%BC%88%E4%B8%89%EF%BC%89%E5%AD%98%E5%82%A8%E7%AE%A1%E7%90%86%E2%80%94%E2%80%94%E5%8A%A8%E6%80%81%E4%B8%8D%E7%AD%89%E9%95%BF%E5%AD%98%E5%82%A8%E8%B5%84%E6%BA%90%E5%88%86%E9%85%8D%E7%AE%97%E6%B3%95/"/>
